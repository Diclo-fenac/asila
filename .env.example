DATABASE_URL=postgresql+asyncpg://asila_app:replace-with-ASILA_DB_APP_PASSWORD@localhost:5432/asila_platform
REDIS_URL=redis://localhost:6379/0
ASILA_SETUP_TOKEN=generate-a-random-one-time-bootstrap-token
ASILA_MASTER_KEY=generate-a-random-encryption-key
ASILA_MULTI_TENANCY_ENABLED=false
POSTGRES_PASSWORD=generate-a-random-postgres-admin-password
ASILA_DB_APP_PASSWORD=generate-a-random-runtime-database-password
ASILA_DB_MIGRATOR_PASSWORD=generate-a-random-migrator-database-password
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_GENERATION_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OIDC_ISSUER=
OIDC_AUDIENCE=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=asila_app
