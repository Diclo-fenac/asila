# ============================================
# ASILA ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in real values.
# NEVER commit .env — only this .env.example file.
# ============================================

# --- Application ---
ENVIRONMENT=development                # development | staging | production
ASILA_MASTER_KEY=                      # Encryption key for provider credentials. Generate: openssl rand -hex 32
ASILA_SETUP_TOKEN=                     # One-time local bootstrap token. Generate: openssl rand -hex 32
ASILA_MULTI_TENANCY_ENABLED=false      # Enable multiple organizations in one deployment
ALLOWED_ORIGINS=http://localhost:5173  # Comma-separated list of allowed CORS origins
OIDC_ISSUER=                          # Generic OIDC issuer URL
OIDC_AUDIENCE=                        # OIDC API audience
OIDC_JWKS_URL=                        # Optional explicit JWKS endpoint
AI_PROVIDER=ollama                    # ollama | openai-compatible | gemini
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_GENERATION_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_GENERATION_MODEL=
OPENAI_EMBEDDING_MODEL=

# --- Runtime Database Role (Postgres) ---
# Use the non-superuser asila_app role in API and worker processes.
# Run Alembic with the separate asila_migrator role instead.
POSTGRES_USER=asila_app
POSTGRES_PASSWORD=                     # Set the asila_app password; never reuse across environments
POSTGRES_DB=asila_platform
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Redis (Task Queue / ARQ) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=                        # Required in production, optional for local dev
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# --- Google Gemini (Vision extraction + generation) ---
GOOGLE_API_KEY=                        # Get from https://aistudio.google.com/apikey
GEMINI_MODEL=gemini-2.5-flash-lite     # Or whichever model version is pinned
EMBEDDING_MODEL=models/gemini-embedding-001

# --- HashiCorp Vault (Optional) ---
# VAULT_URL=http://localhost:8200
# VAULT_TOKEN=
